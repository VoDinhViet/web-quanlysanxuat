# Server-only. Signs the session cookie. Never prefixed with VITE_.
SESSION_SECRET=change-me-to-a-long-random-string

# Public: bundled into the browser. Base URL of the authentication/API service.
VITE_API_URL=http://localhost:8000

# Dev-only. When "true", login is served by src/features/auth/mocks/auth.mock.ts
# instead of VITE_API_URL. The build throws if this is set in a production build.
VITE_USE_MOCK_AUTH=true
