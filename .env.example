# Server-only. Signs the session cookie. Never prefixed with VITE_.
SESSION_SECRET=change-me-to-a-long-random-string

# Public: bundled into the browser at BUILD time. Base URL of the
# authentication/API service — must be reachable from the browser. Under Docker
# it is a build arg, so rebuild the image to change it.
VITE_API_URL=http://localhost:8000

# Optional, docker compose only: used solely by the commented loopback-publish
# line in docker-compose.yml for LOCAL testing without a proxy. In a real deploy
# the app is not mapped to a host port (the platform's proxy reaches it over the
# internal network), so this is ignored. Defaults to 3000.
WEB_PORT=3000
